#!/bin/bash

set -e

# Windows → WSL の一方向同期
WIN_SRC="/mnt/c/repository/portfolio/"
WSL_DST="/home/kaz57guitar/portfolio/"

echo "=== Windows → WSL（正の反映） ==="
rsync -azv --delete \
  --exclude='.vs' \
  --exclude='bin' \
  --exclude='obj' \
  --exclude='node_modules' \
  --exclude='dist' \
  --exclude='.git' \
  --no-perms --no-owner --no-group --no-xattrs \
  "${WIN_SRC}" "${WSL_DST}"

echo "=== 同期完了！（Windows to WSL） ==="
