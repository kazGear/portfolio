#!/bin/bash

set -e

WSL_SRC="/home/kaz57guitar/portfolio/"
WIN_DST="/mnt/c/repository/portfolio/"

echo "=== 1. Windows 側へ差分同期（高速 & 安全） ==="
rsync -azv --delete \
  --exclude='.vs' \
  --exclude='bin' \
  --exclude='obj' \
  --exclude='node_modules' \
  --exclude='dist' \
  --exclude='.git' \
  --no-perms --no-owner --no-group \
  "${WSL_SRC}" "${WIN_DST}"

echo "同期完了"

echo "=== 2. Docker 再ビルド ==="
cd "${WSL_SRC}" || exit 1

docker compose --env-file .env.dev \
  -f compose.base.yaml \
  -f compose.dev.yaml \
  build

echo "=== ビルド完了！ ==="