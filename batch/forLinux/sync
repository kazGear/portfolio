#!/bin/bash

set -e

WIN_BACKEND="/mnt/c/repository/portfolio/backend/"
WSL_BACKEND="/home/kaz57guitar/portfolio/backend/"

WSL_SRC="/home/kaz57guitar/portfolio/"
WIN_DST="/mnt/c/repository/portfolio/"

echo "=== 1. Windows backend → WSL backend（正の反映） ==="
rsync -azv --delete \
  --exclude='.vs' \
  --exclude='bin' \
  --exclude='obj' \
  --no-perms --no-owner --no-group \
  "${WIN_BACKEND}" "${WSL_BACKEND}"

echo "WSL backend(.NET) 更新完了"

echo "=== 2. WSL 全体 → Windows（最終的な正を作る） ==="
rsync -azv --delete \
  --exclude='.vs' \
  --exclude='bin' \
  --exclude='obj' \
  --exclude='node_modules' \
  --exclude='dist' \
  --exclude='.git' \
  --no-perms --no-owner --no-group \
  "${WSL_SRC}" "${WIN_DST}"

echo "Windows side 更新完了"

echo "=== 同期完了！ ==="
