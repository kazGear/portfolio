#!/bin/bash

set -e

# Windows → WSL（backend だけ）
WIN_BACKEND="/mnt/c/repository/portfolio/backend/"
WSL_BACKEND="/home/kaz57guitar/portfolio/backend/"

# WSL → Windows（全体）
WSL_SRC="/home/kaz57guitar/portfolio/"
WIN_DST="/mnt/c/repository/portfolio/"

CHANGED=0

echo "=== 1. Windows backend → WSL backend（正の反映） ==="
rsync -azv --delete \
  --exclude='.vs' \
  --exclude='bin' \
  --exclude='obj' \
  --no-perms --no-owner --no-group \
  "${WIN_BACKEND}" "${WSL_BACKEND}"

if [ $? -ne 0 ]; then
  CHANGED=1
fi

echo "WSL backend(.NET) 更新完了"

echo "=== 2. WSL 全体 → Windows（最終的な正を作る） ==="
rsync -azv --delete \
  --exclude='.vs' \
  --exclude='bin' \
  --exclude='obj' \
  --exclude='node_modules' \
  --exclude='dist' \
  --exclude='.git' \
  --no-perms --no-owner --no-group \
  "${WSL_SRC}" "${WIN_DST}"

if [ $? -ne 0 ]; then
  CHANGED=1
fi

echo "Windows side 更新完了"

if [ $CHANGED -eq 0 ]; then
  echo "=== 差分なし → Docker build スキップ ==="
  echo "=== 同期完了！ ==="
  exit 0
fi

echo "=== 差分あり → Docker 再ビルド ==="
cd "${WSL_SRC}" || exit 1

docker compose --env-file .env.dev \
  -f compose.base.yaml \
  -f compose.dev.yaml \
  build

echo "=== 同期完了！ ==="
